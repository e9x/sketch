{
  "name": "Sketch",
  "namespace": "https://sys32.dev",
  "icon": "https://www.google.com/s2/favicons?sz=64&domain=krunker.io",
  "match": ["https://krunker.io/*", "https://work.ink/4lH/krunker"],
  "exclude": [
    "https://krunker.io/social.html*",
    "https://krunker.io/editor.html*",
    "https://krunker.io/viewer.html*"
  ],
  "antifeature": "ads",
  "grant": [
    "GM_getValue",
    "GM_setValue",
    "GM_listValues",
    "GM_deleteValue",
    "GM_openInTab",
    "GM_xmlhttpRequest"
  ],
  "run-at": "document-start",
  "require": [
    "https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js",
    "https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"
  ]
}
