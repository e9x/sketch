{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ESNext",
    "types": ["tampermonkey", "react/next", "react-dom/next"],
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "baseUrl": "src",
    "strict": true,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "jsx": "react",
    "allowUmdGlobalAccess": true
  },
  "include": ["src/**/*"]
}
