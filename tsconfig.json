{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ESNext",
    "types": ["tampermonkey"],
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "baseUrl": "src",
    "strict": true,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "jsx": "preserve",
    "jsxImportSource": "preact",
    "jsxFactory": "h"
  },
  "include": ["src/**/*"]
}
